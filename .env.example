# App Flipt Configuration
FLIPT_URL=http://localhost:8080
FLIPT_API_TOKEN=your-flipt-api-token-here
FLIPT_NAMESPACE_KEY=default
FLIPT_TIMEOUT_SECONDS=10
REDIS_CONNECTION_STRING=localhost:6379

# Docker Compose Flipt Configuration
FLIPT_IMAGE=flipt/flipt:latest
FLIPT_CONTAINER_NAME=flipt-server
FLIPT_AUTHENTICATION_REQUIRED=false
FLIPT_AUTHENTICATION_METHODS_TOKEN_ENABLED=true
FLIPT_HOST_PORT=8080
FLIPT_CONTAINER_PORT=8080
FLIPT_DATA_PATH=/var/opt/flipt
FLIPT_DATA_VOLUME_NAME=pdi-feature-flags_flipt_data
FLIPT_VOLUME_DRIVER=local
FLIPT_NETWORK_NAME=pdi-feature-flags_flipt_network
FLIPT_NETWORK_DRIVER=bridge
